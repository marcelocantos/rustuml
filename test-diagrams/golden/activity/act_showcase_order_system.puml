@startuml

title Order Processing System

|Customer|
start
:Browse catalog;
:Add items to cart;
:Checkout;

|Order Validation|
if (items in stock?) then (yes)
  if (payment valid?) then (yes)
    note right: Payment validated
    :Confirm order;
  else (no)
    :Payment failed;
    |Customer|
    :Retry payment;
    stop
  endif
else (no)
  :Notify out of stock;
  |Customer|
  stop
endif

|Warehouse|
fork
  :Pick items;
  :Pack items;
fork again
  |Shipping|
  :Generate label;
  :Schedule pickup;
end fork

|Shipping|
repeat
  :Attempt delivery;
backward :Reschedule;
repeatwhile (delivered?) is (no)

|Customer|
:Receive package;
stop
@enduml
