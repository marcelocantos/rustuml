@startuml
' Encapsulation
class BankAccount {
  -balance: double
  -accountNumber: String
  +deposit(amount: double): void
  +withdraw(amount: double): boolean
  +getBalance(): double
}

' Inheritance
abstract class Shape {
  #color: String
  +{abstract} area(): double
  +{abstract} perimeter(): double
  +describe(): void
}
class Circle {
  -radius: double
  +area(): double
  +perimeter(): double
}
class Rectangle {
  -width: double
  -height: double
  +area(): double
  +perimeter(): double
}
Shape <|-- Circle
Shape <|-- Rectangle

' Polymorphism
interface Drawable {
  +draw(): void
}
Circle ..|> Drawable
Rectangle ..|> Drawable

' Abstraction
interface Repository<T> {
  +findById(id: int): T
  +save(entity: T): void
  +delete(id: int): void
  +findAll(): List<T>
}
@enduml
