@startuml

title Breadth-First Search
start
:Initialize queue with start node;
:Mark start as visited;
while (queue not empty?) is (yes)
  :Dequeue node;
  if (node == target?) then (yes)
    :Return found;
    stop
  endif
  :Get unvisited neighbors;
  while (more neighbors?) is (yes)
    :Enqueue neighbor;
    :Mark as visited;
  endwhile
endwhile (empty)
:Return not found;
stop
@enduml
