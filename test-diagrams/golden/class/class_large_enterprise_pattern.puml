@startuml
package domain {
  class User {
    +int id
    +String username
    +String email
  }
  class Order {
    +int id
    +Date createdAt
    +double total
  }
  class Product {
    +int id
    +String name
    +double price
  }
  class OrderItem {
    +int quantity
    +double price
  }
}
package repository {
  interface UserRepository {
    +User findById(int id)
    +List<User> findAll()
  }
  interface OrderRepository {
    +Order findById(int id)
  }
  class UserRepositoryImpl
  class OrderRepositoryImpl
  UserRepositoryImpl ..|> UserRepository
  OrderRepositoryImpl ..|> OrderRepository
}
package service {
  class UserService {
    +User getUser(int id)
    +void createUser(User u)
  }
  class OrderService {
    +Order createOrder(int userId)
    +void addItem(int orderId, int productId)
  }
}
package controller {
  class UserController {
    +void handleGet()
    +void handlePost()
  }
  class OrderController {
    +void handleGet()
    +void handlePost()
  }
}
controller.UserController ..> service.UserService
controller.OrderController ..> service.OrderService
service.UserService ..> repository.UserRepository
service.OrderService ..> repository.OrderRepository
domain.Order --> domain.User
domain.Order *-- domain.OrderItem
domain.OrderItem --> domain.Product
@enduml
