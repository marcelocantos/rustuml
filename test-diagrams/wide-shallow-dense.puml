@startuml

top to bottom direction

package "Core" {
    class Registry
    class EventBus
    class ConfigStore
    class ServiceLocator
    class HealthCheck
}

package "Auth" {
    package "Auth.Internal" {
        class TokenStore
        class SessionManager
        class CredentialValidator
        class PermissionCache
        class AuditLogger
    }
    package "Auth.External" {
        class OAuthProvider
        class SAMLHandler
        class LDAPConnector
        class MFAService
        class CertValidator
    }
}

package "Users" {
    package "Users.Management" {
        class UserService
        class RoleManager
        class GroupService
        class InvitationHandler
        class DeactivationService
    }
    package "Users.Profile" {
        class ProfileStore
        class AvatarService
        class PreferenceManager
        class AddressBook
        class ActivityLog
    }
}

package "Orders" {
    package "Orders.Processing" {
        class OrderPipeline
        class PaymentGateway
        class PriceCalculator
        class DiscountEngine
        class TaxService
    }
    package "Orders.Fulfillment" {
        class ShippingService
        class InventoryCheck
        class WarehouseRouter
        class TrackingService
        class ReturnHandler
    }
}

package "Notifications" {
    package "Notifications.Channels" {
        class EmailSender
        class SMSSender
        class PushNotifier
        class WebhookDispatcher
        class SlackIntegration
    }
    package "Notifications.Templates" {
        class TemplateEngine
        class LocaleResolver
        class BrandingService
        class AttachmentBuilder
        class DeliveryScheduler
    }
}

package "Analytics" {
    package "Analytics.Collection" {
        class EventCollector
        class MetricsAggregator
        class SessionTracker
        class FunnelAnalyzer
        class ABTestRecorder
    }
    package "Analytics.Reporting" {
        class ReportGenerator
        class DashboardService
        class ExportService
        class AlertManager
        class TrendDetector
    }
}

