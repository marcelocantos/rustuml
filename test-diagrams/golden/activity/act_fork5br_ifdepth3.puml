@startuml
start
fork
  :Branch 1 start;
  if (b1cond1?) then (yes)
    if (b1cond2?) then (yes)
      if (b1cond3?) then (yes)
  :Branch 1 work;
      else (no)
        :B1 alt 3;
      endif
    else (no)
      :B1 alt 2;
    endif
  else (no)
    :B1 alt 1;
  endif
