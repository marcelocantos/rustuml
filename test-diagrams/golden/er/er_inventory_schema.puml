@startuml
entity Warehouse {
  * id : INT <<PK>>
  --
  name : VARCHAR(100)
  location : VARCHAR(200)
  capacity : INT
}
entity SKU {
  * id : INT <<PK>>
  --
  code : VARCHAR(50) UNIQUE
  name : VARCHAR(200)
  unit : VARCHAR(20)
  reorder_point : INT
}
entity Stock {
  * warehouse_id : INT <<FK>>
  * sku_id : INT <<FK>>
  --
  quantity : INT
  reserved : INT
  bin_location : VARCHAR(20)
  last_counted : DATE
}
entity PurchaseOrder {
  * id : INT <<PK>>
  * warehouse_id : INT <<FK>>
  --
  supplier_id : INT <<FK>>
  status : VARCHAR(20)
  ordered_at : DATE
  expected_at : DATE
}
entity POLine {
  * po_id : INT <<FK>>
  * sku_id : INT <<FK>>
  --
  ordered_qty : INT
  received_qty : INT
  unit_cost : DECIMAL(10,2)
}
Warehouse ||--o{ Stock : "holds"
SKU ||--o{ Stock : "stored as"
Warehouse ||--o{ PurchaseOrder : "receives"
PurchaseOrder ||--o{ POLine : "contains"
SKU ||--o{ POLine : "ordered as"
@enduml
