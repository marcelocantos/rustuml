@startuml

title Database Transaction
start
:Open connection;
:Begin transaction;
repeat
  :Execute query;
  if (query failed?) then (yes)
    :Log error;
    if (retryable?) then (yes)
      :Wait;
    else (no)
      :Rollback;
      :Close connection;
      stop
    endif
  endif
repeatwhile (more queries?) is (yes)
if (all succeeded?) then (yes)
  :Commit transaction;
else (no)
  :Rollback transaction;
endif
:Close connection;
stop
@enduml
