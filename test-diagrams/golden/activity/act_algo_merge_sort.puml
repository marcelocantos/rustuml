@startuml

title Merge Sort
start
if (size <= 1?) then (yes)
  :Return as-is;
  stop
endif
:Find midpoint;
fork
  :Sort left half recursively;
fork again
  :Sort right half recursively;
end fork
:Merge sorted halves;
:i = 0, j = 0, k = 0;
while (i < left.size AND j < right.size?) is (yes)
  if (left[i] <= right[j]?) then (yes)
    :result[k] = left[i]; i++;
  else (no)
    :result[k] = right[j]; j++;
  endif
  :k++;
endwhile
:Copy remaining left elements;
:Copy remaining right elements;
stop
@enduml
