@startuml
state ComplexSystem {
  state "Module A" as MA {
    [*] --> A_Idle
    A_Idle --> A_Working : start
    A_Working --> A_Idle : done
  }
  --
  state "Module B" as MB {
    state "B_Sub" as BS {
      [*] --> B1
      B1 --> B2
      B2 --> [*]
    }
    [*] --> BS
    BS --> B_Done
    B_Done --> [*]
  }
}

@enduml
