@startuml
state "Step 1" as S1
state "Step 2" as S2
state "Step 3" as S3
state "Compensate 1" as C1
state "Compensate 2" as C2
state "Compensate 3" as C3

[*] --> S1
S1 --> S2 : success
S2 --> S3 : success
S3 --> Done : success
S3 --> C3 : fail
C3 --> C2
C2 --> C1
C1 --> Failed
S2 --> C2 : fail
S1 --> C1 : fail
Done --> [*]
Failed --> [*]
@enduml
