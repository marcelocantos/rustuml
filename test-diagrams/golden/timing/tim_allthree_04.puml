@startuml
robust "R0_4" as r0_4
robust "R1_4" as r1_4
concise "C0_4" as c0_4
binary "B0_4" as b0_4
@0
r0_4 is active
r1_4 is idle
c0_4 is free
b0_4 is high
@100
r0_4 is idle
r1_4 is active
c0_4 is busy
b0_4 is low
@200
r0_4 is active
r1_4 is idle
c0_4 is busy
b0_4 is high
@300
r0_4 is idle
r1_4 is active
c0_4 is free
b0_4 is low

@enduml
