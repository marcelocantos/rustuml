@startuml
entity Person {
  * id : INT <<PK>>
  --
  name : VARCHAR(100)
}
entity Passport {
  * id : INT <<PK>>
  * person_id : INT <<FK>>
  --
  number : VARCHAR(20)
  issued_by : CHAR(2)
  expires : DATE
}
entity DriverLicense {
  * id : INT <<PK>>
  * person_id : INT <<FK>>
  --
  number : VARCHAR(20)
  state : VARCHAR(50)
  class : CHAR(1)
  expires : DATE
}
entity VehicleRegistration {
  * id : INT <<PK>>
  * owner_id : INT <<FK>>
  --
  plate : VARCHAR(10)
  make : VARCHAR(50)
  model : VARCHAR(50)
  year : INT
  vin : CHAR(17)
}
Person ||--o| Passport : "may have"
Person ||--o| DriverLicense : "may have"
Person ||--o{ VehicleRegistration : "may own"
@enduml
