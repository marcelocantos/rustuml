@startuml
box "Box 1" #lightblue
  participant B0A
  participant B0B
end box
box "Box 2" #lightyellow
  participant B1A
  participant B1B
end box
box "Box 3" #lightgreen
  participant B2A
  participant B2B
end box

B0A -> B0B : internal 0
B0B -> B1A : cross 0-1
B1B -> B2A : cross 1-2

par
  B0A -> B0B : par 1
and
  B0A -> B0B : par 2
end
@enduml
