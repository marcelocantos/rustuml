@startuml
state Concurrent {
  [*] --> R0S0
  R0S0 --> R0S1 : step0
  R0S1 --> R0S2 : step1
  R0S2 --> R0S3 : step2
  R0S3 --> [*]
  --
  [*] --> R1S0
  R1S0 --> R1S1 : step0
  R1S1 --> R1S2 : step1
  R1S2 --> R1S3 : step2
  R1S3 --> [*]
  --
  [*] --> R2S0
  R2S0 --> R2S1 : step0
  R2S1 --> R2S2 : step1
  R2S2 --> R2S3 : step2
  R2S3 --> [*]
}
[*] --> Concurrent
Concurrent --> [*]
@enduml
