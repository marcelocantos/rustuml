@startuml
actor User
actor Admin
package "User Operations" {
  usecase "Login"
  usecase "View Profile"
  usecase "Update Profile"
}
package "Admin Operations" {
  usecase "Manage Users"
  usecase "View Logs"
  usecase "Configure System"
}
User --> (Login)
User --> (View Profile)
User --> (Update Profile)
Admin --> (Manage Users)
Admin --> (View Logs)
Admin --> (Configure System)
@enduml
