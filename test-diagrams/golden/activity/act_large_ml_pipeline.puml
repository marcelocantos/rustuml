@startuml

title Machine Learning Training Pipeline

start
partition "Data Collection" {
  :Identify data sources;
  while (more sources?) is (yes)
    :Fetch data from source;
    :Validate data format;
    if (valid?) then (yes)
      :Add to dataset;
    else (no)
      :Log invalid data;
      :Skip record;
    endif
  endwhile
}

partition "Preprocessing" {
  fork
    :Handle missing values;
  fork again
    :Normalize features;
  fork again
    :Encode categorical vars;
  end fork
  :Split train/val/test;
}

partition "Training" {
  :Initialize model;
  :Set hyperparameters;
  repeat
    :Train epoch;
    :Evaluate on validation set;
    if (validation improved?) then (yes)
      :Save checkpoint;
    endif
    :Adjust learning rate;
  repeatwhile (not converged?) is (yes)
}

partition "Evaluation" {
  :Load best checkpoint;
  :Evaluate on test set;
  fork
    :Calculate accuracy;
  fork again
    :Calculate F1 score;
  fork again
    :Calculate AUC-ROC;
  end fork
  if (meets threshold?) then (yes)
    :Promote model;
  else (no)
    :Archive results;
    :Schedule next experiment;
  endif
}
stop
@enduml
