@startuml
entity AuditLog {
  * id : BIGINT <<PK>>
  --
  table_name : VARCHAR(100)
  record_id : BIGINT
  operation : ENUM('INSERT','UPDATE','DELETE')
  old_values : JSONB
  new_values : JSONB
  changed_by : INT <<FK>>
  changed_at : TIMESTAMP
  ip_address : INET
}
entity User {
  * id : INT <<PK>>
  --
  username : VARCHAR(50)
  email : VARCHAR(200)
}
User ||--o{ AuditLog : "makes"
@enduml
