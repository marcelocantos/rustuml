@startuml
box "Frontend" #lightblue
  actor User
  participant UI
end box
box "Backend" #lightyellow
  participant API
  database DB
end box
User -> UI : action
UI -> API : request
alt valid
  API -> DB : query
  DB --> API : data
  API --> UI : 200
else invalid
  API --> UI : 400
end
API --> UI : result
UI --> User : display
@enduml
