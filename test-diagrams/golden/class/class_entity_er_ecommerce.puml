@startuml
entity users {
  *user_id : INT
  --
  username : VARCHAR(50)
  email : VARCHAR(100)
  password_hash : VARCHAR(255)
  created_at : TIMESTAMP
}
entity products {
  *product_id : INT
  --
  name : VARCHAR(100)
  description : TEXT
  price : DECIMAL(10,2)
  stock : INT
  category_id : INT
}
entity orders {
  *order_id : INT
  --
  user_id : INT
  order_date : DATE
  total : DECIMAL(10,2)
  status : VARCHAR(20)
}
entity order_items {
  *item_id : INT
  --
  order_id : INT
  product_id : INT
  quantity : INT
  unit_price : DECIMAL(10,2)
}
entity categories {
  *category_id : INT
  --
  name : VARCHAR(50)
  parent_id : INT
}
entity addresses {
  *address_id : INT
  --
  user_id : INT
  street : VARCHAR(200)
  city : VARCHAR(100)
  country : VARCHAR(50)
  postal_code : VARCHAR(20)
}
entity payments {
  *payment_id : INT
  --
  order_id : INT
  amount : DECIMAL(10,2)
  method : VARCHAR(30)
  status : VARCHAR(20)
  paid_at : TIMESTAMP
}
entity reviews {
  *review_id : INT
  --
  user_id : INT
  product_id : INT
  rating : TINYINT
  comment : TEXT
  created_at : TIMESTAMP
}
users ||--o{ orders : places
orders ||--o{ order_items : contains
products ||--o{ order_items : included_in
products }o--|| categories : belongs_to
orders ||--|| payments : paid_by
users ||--o{ addresses : has
users ||--o{ reviews : writes
products ||--o{ reviews : receives
@enduml
