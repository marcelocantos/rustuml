@startuml

start
:Initialize connection;
repeat
  :Attempt operation;
  if (succeeded?) then (yes)
    :Process result;
    break
  else (no)
    if (retries exceeded?) then (yes)
      :Log fatal error;
      stop
    else (no)
      :Wait before retry;
    endif
  endif
backward :Increment retry count;
repeatwhile (not done?) is (retry)
:Finalize;
stop
@enduml
