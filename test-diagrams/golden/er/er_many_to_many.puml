@startuml
entity Student {
  * id : INT <<PK>>
  --
  name : VARCHAR(100)
  email : VARCHAR(200)
}
entity Course {
  * id : INT <<PK>>
  --
  title : VARCHAR(200)
  credits : INT
}
entity Enrollment {
  * student_id : INT <<FK>>
  * course_id : INT <<FK>>
  --
  enrolled_at : DATETIME
  grade : CHAR(2)
}
Student ||--o{ Enrollment : "enrolls in"
Course ||--o{ Enrollment : "has"
@enduml
