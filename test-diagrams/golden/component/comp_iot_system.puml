@startuml
node "IoT Device" {
  component Sensor
  component Firmware
}
cloud "MQTT Broker" {
  component Broker
}
package "Backend" {
  component "Data Ingestion" as DI
  component "Stream Processor" as SP
  database "Time Series DB" as TSDB
}
package "Frontend" {
  component Dashboard
  component AlertManager
}
Firmware --> Broker : MQTT
Broker --> DI : stream
DI --> SP
SP --> TSDB
Dashboard --> TSDB : query
AlertManager --> TSDB : monitor
@enduml
