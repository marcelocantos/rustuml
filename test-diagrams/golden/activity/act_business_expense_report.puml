@startuml

title Expense Report Process

|Employee|
start
:Create expense report;
:Attach receipts;
:Submit report;

|Manager|
:Review report;
if (amount <= limit?) then (yes)
  :Approve;
  |Finance|
  :Process reimbursement;
  |Employee|
  :Receive payment;
  stop
else (no)
  if (needs director?) then (yes)
    |Director|
    :Review large expense;
    if (director approves?) then (yes)
      |Finance|
      :Process reimbursement;
      |Employee|
      :Receive payment;
      stop
    else (no)
      |Employee|
      :Report rejected;
      stop
    endif
  else (no)
    |Employee|
    :Report rejected;
    stop
  endif
endif
@enduml
