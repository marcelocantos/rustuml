@startuml
start
if (L1?) then (yes)
  if (L2?) then (yes)
    if (L3?) then (yes)
      while (W1?) is (yes)
        while (W2?) is (yes)
          :Innermost action;
        endwhile
      endwhile
    else (no)
      :Alt 1;
    endif
  else (no)
    :Alt 2;
  endif
else (no)
  :Alt 3;
endif
stop
@enduml
