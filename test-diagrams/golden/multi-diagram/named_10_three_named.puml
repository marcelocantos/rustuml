@startuml flow
Alice -> Bob : Hello
Bob --> Alice : Hi there
@enduml

@startuml model
class Animal {
  +String name
  +void speak()
}
class Dog {
  +void fetch()
}
Animal <|-- Dog
@enduml

@startuml states
[*] --> Idle
Idle --> Running : start
Running --> Idle : stop
Running --> [*] : finish
@enduml
