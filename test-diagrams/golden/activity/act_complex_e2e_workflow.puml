@startuml

title End-to-End Order Processing

|Customer|
start
:Place order;
|Order Service|
:Validate order;
if (valid?) then (yes)
  fork
    |Inventory|
    :Reserve items;
    fork again
    |Payment|
    :Charge customer;
  end fork
  if (all succeeded?) then (yes)
    |Fulfillment|
    :Pack order;
    :Ship order;
    |Customer|
    :Receive confirmation;
    stop
  else (no)
    |Order Service|
    :Rollback;
    |Customer|
    :Notify failure;
    stop
  endif
else (no)
  |Customer|
  :Show validation errors;
  stop
endif
@enduml
