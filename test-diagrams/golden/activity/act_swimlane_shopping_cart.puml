@startuml

title Shopping Cart Checkout

|Customer|
start
:View cart;
:Enter shipping address;

|Payment System|
:Request payment details;
|Customer|
:Provide payment;

|Payment System|
if (payment authorized?) then (yes)
  |Inventory|
  fork
    :Reserve item A;
  fork again
    :Reserve item B;
  fork again
    :Reserve item C;
  end fork
  if (all reserved?) then (yes)
    |Fulfillment|
    :Create shipment;
    |Customer|
    :Send confirmation email;
    stop
  else (no)
    |Payment System|
    :Refund payment;
    |Customer|
    :Notify partial failure;
    stop
  endif
else (no)
  |Customer|
  :Payment declined notice;
  stop
endif
@enduml
