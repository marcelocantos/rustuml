@startuml
note "Crow's Foot Notation Examples" as N

entity A {
  * id : INT <<PK>>
}
entity B {
  * id : INT <<PK>>
}
entity C {
  * id : INT <<PK>>
}
entity D {
  * id : INT <<PK>>
}
entity E {
  * id : INT <<PK>>
}
entity F {
  * id : INT <<PK>>
}

A ||--|| B : "one to one"
A ||--o| C : "one to zero-or-one"
A ||--|{ D : "one to one-or-many"
A ||--o{ E : "one to zero-or-many"
A }|--|{ F : "many-or-one to many-or-one"
@enduml
