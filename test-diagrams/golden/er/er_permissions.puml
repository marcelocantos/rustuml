@startuml
entity User {
  * id : INT <<PK>>
  --
  username : VARCHAR(50)
  is_active : BOOLEAN
}
entity Role {
  * id : INT <<PK>>
  --
  name : VARCHAR(100) UNIQUE
  description : TEXT
}
entity Permission {
  * id : INT <<PK>>
  --
  resource : VARCHAR(100)
  action : VARCHAR(50)
  description : TEXT
}
entity UserRole {
  * user_id : INT <<FK>>
  * role_id : INT <<FK>>
  --
  granted_at : DATETIME
  granted_by : INT <<FK>>
}
entity RolePermission {
  * role_id : INT <<FK>>
  * permission_id : INT <<FK>>
}
User ||--o{ UserRole : "has"
Role ||--o{ UserRole : "assigned to"
Role ||--o{ RolePermission : "grants"
Permission ||--o{ RolePermission : "granted by"
@enduml
