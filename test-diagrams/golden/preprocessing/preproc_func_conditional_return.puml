@startuml
!function $classify($n)
  !if $n < 0
    !return "negative"
  !elseif $n == 0
    !return "zero"
  !elseif $n < 10
    !return "small"
  !else
    !return "large"
  !endif
!endfunction

note as N
  classify(-5) = $classify(-5)
  classify(0) = $classify(0)
  classify(7) = $classify(7)
  classify(42) = $classify(42)
end note
@enduml
