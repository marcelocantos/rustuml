@startuml
entity Order {
  * id : INT <<PK>>
  --
  customer_id : INT <<FK>>
  order_date : DATE
}
entity OrderItem {
  * order_id : INT <<PK,FK>>
  * line_num : INT <<PK>>
  --
  product_id : INT <<FK>>
  quantity : INT
  unit_price : DECIMAL(10,2)
}
entity Product {
  * id : INT <<PK>>
  --
  name : VARCHAR(200)
  price : DECIMAL(10,2)
}
Order ||--o{ OrderItem : "contains"
Product ||--o{ OrderItem : "included in"
@enduml
