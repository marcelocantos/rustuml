@startuml
class User {
  +int id
  +String username
  +String email
  +void register()
  +void login()
}
class Product {
  +int id
  +String name
  +double price
  +int stock
}
class Cart {
  +List<CartItem> items
  +double total()
  +void addItem(Product p)
  +void removeItem(Product p)
}
class CartItem {
  +Product product
  +int quantity
  +double subtotal()
}
class Order {
  +int id
  +Date createdAt
  +OrderStatus status
}
enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}
User "1" -- "1" Cart
Cart "1" *-- "*" CartItem
CartItem --> Product
User "1" -- "*" Order
Order --> OrderStatus
@enduml
