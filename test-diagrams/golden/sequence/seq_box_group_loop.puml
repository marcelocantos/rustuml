@startuml
box "Frontend" #lightblue
  actor User
  participant UI
end box
box "Backend" #lightyellow
  participant API
  database DB
end box
User -> UI : action
UI -> API : request
loop for each item
  API -> DB : fetch
  DB --> API : item
  API -> UI : push
end
API --> UI : result
UI --> User : display
@enduml
