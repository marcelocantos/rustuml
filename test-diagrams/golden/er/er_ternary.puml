@startuml
entity Doctor {
  * id : INT <<PK>>
  --
  name : VARCHAR(100)
  specialty : VARCHAR(100)
}
entity Patient {
  * id : INT <<PK>>
  --
  name : VARCHAR(100)
  dob : DATE
}
entity Hospital {
  * id : INT <<PK>>
  --
  name : VARCHAR(200)
  city : VARCHAR(100)
}
entity Appointment {
  * doctor_id : INT <<FK>>
  * patient_id : INT <<FK>>
  * hospital_id : INT <<FK>>
  --
  scheduled_at : DATETIME
  duration_min : INT
  notes : TEXT
}
Doctor ||--o{ Appointment : "attends"
Patient ||--o{ Appointment : "has"
Hospital ||--o{ Appointment : "hosts"
@enduml
