  --
  [*] --> R1S0
  R1S0 --> R1S1 : step0
  R1S1 --> R1S2 : step1
  R1S2 --> [*]
  --
  [*] --> R2S0
  R2S0 --> R2S1 : step0
  R2S1 --> R2S2 : step1
  R2S2 --> [*]
  --
  [*] --> R3S0
  R3S0 --> R3S1 : step0
  R3S1 --> R3S2 : step1
  R3S2 --> [*]
  --
  [*] --> R4S0
  R4S0 --> R4S1 : step0
  R4S1 --> R4S2 : step1
  R4S2 --> [*]
}
[*] --> Concurrent
Concurrent --> [*]
@enduml
