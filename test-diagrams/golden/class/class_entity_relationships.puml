@startuml
entity Customer {
  *customer_id : INT
  name : VARCHAR
  email : VARCHAR
}
entity Order {
  *order_id : INT
  customer_id : INT
  order_date : DATE
}
entity OrderItem {
  *item_id : INT
  order_id : INT
  product_id : INT
  quantity : INT
}
Customer ||--o{ Order : places
Order ||--o{ OrderItem : contains
@enduml
